rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Shared Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isRestaurantOwner(restaurantId) {
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function isRestaurantOwnerOrStaff(restaurantId) {
      let restaurantData = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      return isSignedIn() && (restaurantData.ownerId == request.auth.uid || 
             (restaurantData.staffEmails != null && request.auth.token.email in restaurantData.staffEmails));
    }

    // Entity Validations
    function isValidRestaurant(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid;
    }
    
    // ... (keep the rest of the file)

    function isValidMenuItem(data) {
      return data.keys().hasAll(['restaurantId', 'name', 'price', 'category', 'isAvailable']) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.isAvailable is bool;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['restaurantId', 'tableNo', 'customerName', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.restaurantId is string &&
             data.tableNo is string &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number &&
             data.status in ['PENDING', 'ACCEPTED', 'PREPARING', 'COMPLETED', 'CANCELLED'];
    }

    function isValidStoreCustomer(data) {
      return data.keys().hasAll(['restaurantId', 'name', 'code', 'creditBalance', 'createdAt']) &&
             data.restaurantId is string &&
             data.name is string &&
             data.code is string &&
             data.creditBalance is number;
    }

    match /storeCustomers/{customerId} {
      // Relaxed read to ensure no list query disruptions, rely on UI to not expose other restaurants
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isRestaurantOwnerOrStaff(incoming().restaurantId) && isValidStoreCustomer(incoming());
      allow update: if isSignedIn() && isRestaurantOwnerOrStaff(existing().restaurantId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['creditBalance']);
      allow delete: if isSignedIn() && isRestaurantOwner(existing().restaurantId);
    }

    match /staffCodes/{code} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && isRestaurantOwner(request.resource.data.restaurantId);
    }

    match /restaurants/{restaurantId} {
      allow get: if true;
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || (resource.data.staffEmails != null && request.auth.token.email in resource.data.staffEmails));
      allow create: if isSignedIn() && isValidRestaurant(incoming());
      allow update: if isSignedIn() && isRestaurantOwner(restaurantId) && isValidRestaurant(incoming());
      allow delete: if isSignedIn() && isRestaurantOwner(restaurantId);
    }

    match /menuItems/{menuItemId} {
      allow read: if true;
      allow create: if isSignedIn() && isRestaurantOwnerOrStaff(incoming().restaurantId) && isValidMenuItem(incoming());
      allow update: if (isSignedIn() && isRestaurantOwnerOrStaff(existing().restaurantId) && isValidMenuItem(incoming())) || (
        // Allow unauth stockCount updates for orders
        incoming().diff(existing()).affectedKeys().hasOnly(['stockCount']) && incoming().stockCount is number
      );
      allow delete: if isSignedIn() && isRestaurantOwnerOrStaff(existing().restaurantId);
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      // For listing orders, strictly enforce ownership. 
      // Note: isRestaurantOwnerOrStaff uses get(), which is valid for list queries if optimized by query filters.
      allow read: if isSignedIn() && isRestaurantOwnerOrStaff(existing().restaurantId); 
      allow update: if (isSignedIn() && isRestaurantOwnerOrStaff(existing().restaurantId) && (
        // Only allow updating status and updatedAt
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        incoming().status in ['ACCEPTED', 'PREPARING', 'COMPLETED', 'CANCELLED']
      )) || (
        // Allow unauthenticated tableNo update
        incoming().diff(existing()).affectedKeys().hasOnly(['tableNo']) && incoming().tableNo is string
      );
      allow delete: if isSignedIn() && isRestaurantOwner(existing().restaurantId);
    }

    match /inviteRequests/{requestId} {
      allow create: if isSignedIn();
      allow list: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /qrTables/{qrTableId} {
      allow read: if true; // Public scan access
      allow create: if isSignedIn() && isRestaurantOwner(incoming().restaurantId);
      allow update, delete: if isSignedIn() && isRestaurantOwner(existing().restaurantId);
    }
  }
}
